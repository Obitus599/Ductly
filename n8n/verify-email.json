{
  "name": "Ductly — Verify Email (OTP)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "verify-email",
        "responseMode": "onReceived",
        "responseData": "allEntries",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook: Verify Email",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [220, 300],
      "webhookId": "verify-email"
    },
    {
      "parameters": {
        "fromEmail": "noreply@ductly.ae",
        "toEmail": "={{ $json.body.email }}",
        "subject": "Your Ductly verification code: {{ $json.body.code }}",
        "emailType": "html",
        "html": "<!DOCTYPE html>\n<html>\n<head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"></head>\n<body style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f7f8fa; padding: 40px 20px;\">\n<div style=\"max-width: 520px; margin: 0 auto; background: white; border-radius: 16px; border: 2px solid #eef0f4; padding: 40px; text-align: center;\">\n  <img src=\"https://ductly.ae/images/logo.png\" alt=\"Ductly\" style=\"height: 36px; margin-bottom: 24px;\" />\n  <h1 style=\"font-size: 22px; color: #3d3d3d; margin: 0 0 8px;\">Verify your email</h1>\n  <p style=\"color: #a0a5af; font-size: 14px; margin: 0 0 24px;\">Enter this code on the Ductly booking page to confirm your email address.</p>\n  <div style=\"font-size: 34px; font-weight: 700; letter-spacing: 8px; color: #3d3d3d; background: #fcfcfc; border: 1px solid #f4f4f4; border-radius: 12px; padding: 18px 0; margin-bottom: 20px;\">{{ $json.body.code }}</div>\n  <p style=\"font-size: 13px; color: #a0a5af;\">This code expires in {{ $json.body.ttl_minutes }} minutes. If you didn't request it, you can safely ignore this email.</p>\n</div>\n</body>\n</html>",
        "options": {}
      },
      "id": "send-email",
      "name": "Send Verification Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [460, 300],
      "credentials": {
        "smtp": {
          "id": "CONFIGURE_ME",
          "name": "SMTP — reuse the same credential as Booking Confirmed"
        }
      }
    }
  ],
  "connections": {
    "Webhook: Verify Email": {
      "main": [
        [{ "node": "Send Verification Email", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
