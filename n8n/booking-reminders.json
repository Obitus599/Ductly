            { "name": "ContentSid", "value": "={{ $env.TWILIO_CONTENT_SID_BOOKING_REMINDER_1H }}" },
            { "name": "ContentVariables", "value": "={{ JSON.stringify({\n  '1': $json.customer_name,\n  '2': $json.slot_start,\n  '3': $json.team_name || 'Your assigned team'\n}) }}" }
          ]
        },
        "options": {}
      },
      "id": "whatsapp-1h",
      "name": "WhatsApp: 1h Reminder",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 400],
      "credentials": {
        "httpBasicAuth": {
          "id": "CONFIGURE_ME",
