# ─── Required ────────────────────────────────────────────────────────────────
# Supabase project credentials (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (Dashboard → Developers → API keys / Webhooks)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Public URL of the deployed app (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Optional ────────────────────────────────────────────────────────────────
# Admin panel authentication key (for programmatic access via x-admin-key header)
# If unset, admin access is open in development and blocked in production.
# ADMIN_API_KEY=your-admin-key

# Google Maps — Server key (Geocoding + Distance Matrix for travel-time calculations)
# Must NOT have HTTP referrer restrictions (use IP restriction or none).
# Falls back to GOOGLE_MAPS_API_KEY if unset.
# If unset, slot availability uses a flat 20-minute buffer instead of real travel times.
# GOOGLE_MAPS_SERVER_KEY=your-server-google-maps-key

# Google Maps — legacy fallback server key (deprecated in favor of GOOGLE_MAPS_SERVER_KEY)
# GOOGLE_MAPS_API_KEY=your-google-maps-key

# Google Maps (Client-side — address picker map + Places Autocomplete)
# Must have Maps JavaScript API + Places API enabled.
# If unset, booking form falls back to a plain text address input.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key

# OpenRouter (GPT-4o for AI team assignment in Layer 2)
# If unset, team assignment falls back to deterministic least-booked rule.
# OPENROUTER_API_KEY=your-openrouter-key

# n8n Webhooks (Automation: WhatsApp + Email notifications)
# If unset, no notifications are triggered. App works fine without them.
# N8N_WEBHOOK_BOOKING_CONFIRMED=https://your-n8n.example.com/webhook/booking-confirmed
# N8N_WEBHOOK_PAYMENT_FAILED=https://your-n8n.example.com/webhook/payment-failed
# N8N_WEBHOOK_TEAM_DISPATCH=https://your-n8n.example.com/webhook/team-dispatch
# N8N_WEBHOOK_BOOKING_CANCELLED=https://your-n8n.example.com/webhook/booking-cancelled
# N8N_WEBHOOK_OPS_ALERT=https://your-n8n.example.com/webhook/ops-alert

# ─── Transactional email (Resend) ────────────────────────────────────────────
# The customer verification (OTP) email is rendered in-app and sent directly
# via the Resend HTTP API — no template engine in the middle, so no {{ }}
# markup can leak. If RESEND_API_KEY is unset, the app falls back to the
# N8N_WEBHOOK_VERIFY_EMAIL relay below.
# RESEND_API_KEY=re_...
# EMAIL_FROM=Ductly <noreply@ductly.ae>   # must be a verified Resend sender
#
# Fallback only — n8n email relay for the OTP (used when RESEND_API_KEY unset):
# N8N_WEBHOOK_VERIFY_EMAIL=https://your-n8n.example.com/webhook/verify-email

# ─── Customer verification (#7) — OTP before booking ─────────────────────────
# Email and phone are gated independently. Email rides on Resend (always
# works); phone rides on WhatsApp (needs a Meta-approved template). Always
# pair each server flag with its NEXT_PUBLIC_ twin so the OTP UI renders.
#
# Require a verified EMAIL before checkout (recommended once Resend is set):
# REQUIRE_CONTACT_VERIFICATION=true
# NEXT_PUBLIC_REQUIRE_CONTACT_VERIFICATION=true
#
# ALSO require a verified PHONE — only turn on AFTER the WhatsApp
# ductly_verify_code template is approved and TWILIO_* are set in this app:
# REQUIRE_PHONE_VERIFICATION=true
# NEXT_PUBLIC_REQUIRE_PHONE_VERIFICATION=true

# ─── Twilio (WhatsApp BSP) — used by n8n AND this Next.js app ─────────────────
# Some WhatsApp sends go through n8n (booking confirmations, reminders,
# no-show follow-ups). Others go directly from this Next.js app (invoice
# delivery, job-status prompts, ops alerts, team reachability pings, phone
# OTP verification). BOTH environments need these credentials.
#
# Twilio Console → Account dashboard
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_WHATSAPP_FROM=whatsapp:+15559870195
#
# ─── n8n-referenced Content SIDs ─────────────────────────────────────────────
# TWILIO_CONTENT_SID_BOOKING_CONFIRMED=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_CONTENT_SID_BOOKING_REMINDER_24H=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_CONTENT_SID_BOOKING_REMINDER_1H=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_CONTENT_SID_FEEDBACK_REQUEST=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_CONTENT_SID_NO_SHOW_FOLLOWUP=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_CONTENT_SID_TEAM_DISPATCH=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# ─── App-referenced Content SIDs (read directly by Next.js code) ──────────────
# TWILIO_CONTENT_SID_DUCTLY_INVOICE=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_CONTENT_SID_DUCTLY_JOB_STATUS=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_CONTENT_SID_DUCTLY_OPS_ALERT=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_CONTENT_SID_DUCTLY_PING=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_CONTENT_SID_DUCTLY_VERIFY=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google Analytics 4 ──────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-xxxxxxxxxx
