# ─── Required ────────────────────────────────────────────────────────────────
# Supabase project credentials (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (Dashboard → Developers → API keys / Webhooks)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Public URL of the deployed app (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Optional ────────────────────────────────────────────────────────────────
# Admin panel authentication key (for programmatic access via x-admin-key header)
# If unset, admin access is open in development and blocked in production.
# ADMIN_API_KEY=your-admin-key

# Google Maps — Server key (Geocoding + Distance Matrix for travel-time calculations)
# Must NOT have HTTP referrer restrictions (use IP restriction or none).
# Falls back to GOOGLE_MAPS_API_KEY if unset.
# If unset, slot availability uses a flat 20-minute buffer instead of real travel times.
# GOOGLE_MAPS_SERVER_KEY=your-server-google-maps-key

# Google Maps — legacy fallback server key (deprecated in favor of GOOGLE_MAPS_SERVER_KEY)
# GOOGLE_MAPS_API_KEY=your-google-maps-key

# Google Maps (Client-side — address picker map + Places Autocomplete)
# Must have Maps JavaScript API + Places API enabled.
# If unset, booking form falls back to a plain text address input.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key

# OpenRouter (GPT-4o for AI team assignment in Layer 2)
# If unset, team assignment falls back to deterministic least-booked rule.
# OPENROUTER_API_KEY=your-openrouter-key

# n8n Webhooks (Automation: WhatsApp + Email notifications)
# If unset, no notifications are triggered. App works fine without them.
# N8N_WEBHOOK_BOOKING_CONFIRMED=https://your-n8n.example.com/webhook/booking-confirmed
# N8N_WEBHOOK_PAYMENT_FAILED=https://your-n8n.example.com/webhook/payment-failed
# N8N_WEBHOOK_TEAM_DISPATCH=https://your-n8n.example.com/webhook/team-dispatch
